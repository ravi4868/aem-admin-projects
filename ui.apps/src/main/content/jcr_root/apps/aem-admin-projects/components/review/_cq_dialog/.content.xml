<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Review Dialog"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <content jcr:primaryType="nt:unstructured" jcr:title="Review Content" sling:resourceType="granite/ui/components/foundation/section">
                        <layout jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/layouts/fixedcolumns"/>
                        <items jcr:primaryType="nt:unstructured">
                            <column jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <reviewTitle jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/form/textfield" fieldLabel="Review Title" name="./reviewTitle" required="{Boolean}true"/>
                                    <reviewContent jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/form/textarea" fieldLabel="Review Content" name="./reviewContent" required="{Boolean}true"/>
                                    <reviewDate jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/form/datepicker" fieldLabel="Review Date" name="./reviewDate"/>
                                </items>
                            </column>
                        </items>
                    </content>
                    <reviewer jcr:primaryType="nt:unstructured" jcr:title="Reviewer Information" sling:resourceType="granite/ui/components/foundation/section">
                        <layout jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/layouts/fixedcolumns"/>
                        <items jcr:primaryType="nt:unstructured">
                            <column jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <reviewerName jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/form/textfield" fieldLabel="Reviewer Name" name="./reviewerName" required="{Boolean}true"/>
                                    <verified jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/form/checkbox" fieldLabel="Verified Purchase" name="./verified" text="Verified" value="true"/>
                                    <helpfulCount jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/form/number" fieldLabel="Helpful Count" name="./helpfulCount" min="0"/>
                                </items>
                            </column>
                        </items>
                    </reviewer>
                    <ratings jcr:primaryType="nt:unstructured" jcr:title="Ratings" sling:resourceType="granite/ui/components/foundation/section">
                        <layout jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/layouts/fixedcolumns"/>
                        <items jcr:primaryType="nt:unstructured">
                            <column jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <overallRating jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/form/number" fieldLabel="Overall Rating (1-5)" name="./overallRating" min="1" max="5" required="{Boolean}true"/>
                                    <tasteRating jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/form/number" fieldLabel="Taste Rating (1-5)" name="./tasteRating" min="1" max="5"/>
                                    <presentationRating jcr:primaryType="nt:unstructured" sling:resourceType="granite/ui/components/foundation/form/number" fieldLabel="Presentation Rating (1-5)" name="./presentationRating" min="1" max="5"/>
                                </items>
                            </column>
                        </items>
                    </ratings>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
