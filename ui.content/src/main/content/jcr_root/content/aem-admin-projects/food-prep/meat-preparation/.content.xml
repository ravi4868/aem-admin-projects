<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          jcr:primaryType="cq:Page">
    <jcr:content
        jcr:primaryType="cq:PageContent"
        jcr:title="Guide - Meat Preparation Methods"
        sling:resourceType="cq:Page">
        <par jcr:primaryType="nt:unstructured"
             sling:resourceType="wcm/foundation/components/responsivegrid">
            <foodprep
                jcr:primaryType="nt:unstructured"
                sling:resourceType="aem-admin-projects/components/food-preparation"
                preparationTitle="Meat Preparation Methods"
                foodCategory="Meat & Poultry"
                difficultyLevel="Intermediate"
                description="Master the art of preparing different cuts of meat for optimal results. Learn trimming, marinating, and seasoning techniques that professional chefs use.">
                <tools jcr:primaryType="nt:unstructured">
                    <tool1>Butcher's Knife</tool1>
                    <tool2>Meat Tenderizer</tool2>
                    <tool3>Cutting Board</tool3>
                    <tool4>Boning Knife</tool4>
                    <tool5>Kitchen Shears</tool5>
                </tools>
                <ingredients jcr:primaryType="nt:unstructured">
                    <ingredient1>Chicken Breast</ingredient1>
                    <ingredient2>Beef Steak</ingredient2>
                    <ingredient3>Pork Chops</ingredient3>
                    <ingredient4>Lamb Chops</ingredient4>
                    <ingredient5>Turkey Breast</ingredient5>
                </ingredients>
                <techniques jcr:primaryType="nt:unstructured">
                    <technique1>Trimming Fat</technique1>
                    <technique2>Portioning Cuts</technique2>
                    <technique3>Butterflying</technique3>
                    <technique4>Pounding</technique4>
                    <technique5>Marinating</technique5>
                </techniques>
                <proTips jcr:primaryType="nt:unstructured">
                    <tip1>Always trim excess fat before cooking</tip1>
                    <tip2>Remove meat from refrigerator 30 minutes before cooking</tip2>
                    <tip3>Pat meat dry before cooking for better browning</tip3>
                    <tip4>Marinate at least 2 hours for maximum flavor</tip4>
                    <tip5>Let cooked meat rest before cutting</tip5>
                </proTips>
            </foodprep>
        </par>
    </jcr:content>
</jcr:root>